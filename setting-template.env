# Sam Nav 本機覆蓋設定範本
# 優先序：Docker compose / 系統環境變數 > setting.env > site/deffault.env
#
# 不使用 Docker、直接執行 `cd site && go run .` 時，可複製此檔為 setting.env 後調整。
# setting.env 可放本機私密設定，已加入 .gitignore，不會提交。

SAM_NAV_PORT=6412
SAM_NAV_DATA_DIR=./data
SAM_NAV_DB_PATH=./data/nav.sqlite
SAM_NAV_SITE_TITLE=Sam Nav
SAM_NAV_VERSION=v0.2.2
SAM_NAV_BUILD_HASH=
SAM_NAV_BASE_URL=http://127.0.0.1:6412
SAM_NAV_LANG=zhTW
SAM_NAV_DEFAULT_THEME=light
SAM_NAV_OPEN_IN_NEW_TAB=1

# 初始管理員帳號；服務對外開放前請先修改。
SAM_NAV_AUTH_USERNAME=admin
SAM_NAV_AUTH_PASSWORD=admin
SAM_NAV_AUTH_SECRET_KEY=
SAM_NAV_AUTH_ALLOWED_NETWORKS=

# 容器預設值
PUID=1000
PGID=1000
TZ=Asia/Taipei
